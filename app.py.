import edge_tts
import os
from datetime import datetime

# Cấu hình giao diện Doanlifestyle Pro Studio
st.set_page_config(page_title="Doanlifestyle Pro", layout="wide", page_icon="🎙️")

# CSS tạo giao diện màu Kem/Nâu như ảnh mẫu của bạn
st.markdown("""
    <style>
    .stApp { background-color: #f5ece2; }
